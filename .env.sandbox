# ╔══════════════════════════════════════════════════════════════════╗
# ║  TRYB SANDBOX — demo/development bez GPU i bez prawdziwego modelu ║
# ║  Frontend używa wbudowanych danych mock, vLLM NIE jest uruchamiane║
# ╚══════════════════════════════════════════════════════════════════╝
APP_ENV=sandbox

# Frontend — włącza tryb demo (mock dane, brak zapytań do backendu)
VITE_DEMO_MODE=true

# Baza danych (lokalny PostgreSQL w Dockerze)
POSTGRES_USER=czat_admin
POSTGRES_PASSWORD=sandbox_password
POSTGRES_DB=czat_umowy

# Backend
SECRET_KEY=sandbox-dev-secret-key-not-for-production
DOCUMENTS_PATH=/data/documents

# HuggingFace — niepotrzebny w sandbox (model nie jest pobierany)
HF_TOKEN=
