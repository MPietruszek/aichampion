# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  .env.example — szablon zmiennych środowiskowych                         ║
# ║                                                                          ║
# ║  NIE używaj tego pliku bezpośrednio. Skopiuj odpowiedni plik:            ║
# ║    tryb demo/dev:  cp .env.sandbox .env  (lub: make sandbox)             ║
# ║    tryb prod:      cp .env.prod .env     (lub: make prod)                ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Tryb działania: sandbox | prod
APP_ENV=sandbox

# Frontend — true = tryb mock (bez GPU), false = prawdziwy backend + model
VITE_DEMO_MODE=true

# PostgreSQL
POSTGRES_USER=czat_admin
POSTGRES_PASSWORD=zmien_to_haslo
POSTGRES_DB=czat_umowy

# Backend
SECRET_KEY=zmien_ten_klucz_na_produkcji

# HuggingFace Token (wymagany tylko w trybie prod do pobrania modelu PLLuM)
# Wygeneruj na: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
